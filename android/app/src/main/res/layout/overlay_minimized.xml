<?xml version="1.0" encoding="utf-8"?>
<!-- Minimized: Improved Chat-Head — larger gradient ball with glow -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="64dp"
    android:layout_height="64dp">

    <ImageView
        android:id="@+id/chat_head"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_chathead_improved"
        android:src="@drawable/ic_overlay_logo"
        android:scaleType="centerInside"
        android:padding="12dp"
        android:elevation="12dp"
        android:contentDescription="AI Agent" />

</FrameLayout>
