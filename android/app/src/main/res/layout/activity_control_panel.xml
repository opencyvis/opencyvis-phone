<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF0D0D0D"
    android:fitsSystemWindows="true">

    <!-- Status bar -->
    <LinearLayout
        android:id="@+id/status_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="@drawable/bg_status_bar">

        <!-- Accent dot indicator -->
        <View
            android:id="@+id/status_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/fab_background" />

        <TextView
            android:id="@+id/text_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="OpenCyvis"
            android:textSize="18sp"
            android:textColor="#E0FFFFFF"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.02" />

        <Button
            android:id="@+id/btn_minimize"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="▢"
            android:textSize="18sp"
            android:minWidth="44dp"
            style="?android:attr/buttonBarButtonStyle"
            android:contentDescription="@string/vd_cd_minimize"
            android:textColor="#80FFFFFF" />

        <Button
            android:id="@+id/btn_history"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="🕓"
            android:textSize="18sp"
            android:minWidth="44dp"
            style="?android:attr/buttonBarButtonStyle"
            android:textColor="#80FFFFFF" />

        <Button
            android:id="@+id/btn_memory"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/btn_memory_label"
            android:textSize="15sp"
            android:minWidth="44dp"
            style="?android:attr/buttonBarButtonStyle"
            android:textColor="#80FFFFFF" />

        <Button
            android:id="@+id/btn_settings"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="⚙"
            android:textSize="18sp"
            android:minWidth="44dp"
            style="?android:attr/buttonBarButtonStyle"
            android:textColor="#80FFFFFF" />
    </LinearLayout>

    <!-- Subtle divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1AFFFFFF" />

    <!-- Recent tasks (shown when idle, hidden when agent active) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FF0D0D0D">

        <!-- Chat messages -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_chat"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"
            android:clipToPadding="false" />

        <!-- Idle state: recent tasks -->
        <LinearLayout
            android:id="@+id/recent_tasks_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Tasks"
                android:textColor="#555555"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_recent_tasks"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false" />

            <TextView
                android:id="@+id/btn_view_all_history"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="View all history →"
                android:textColor="#80A0FF"
                android:textSize="12sp"
                android:padding="12dp"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Bottom input bar -->
    <LinearLayout
        android:id="@+id/input_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FF141414"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp">

        <!-- Action buttons row -->
        <LinearLayout
            android:id="@+id/action_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/btn_view_operation"
                style="@style/OpenCyvis.Button.Custom"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="View"
                android:textSize="13sp"
                android:textColor="#B0FFFFFF"
                android:background="@drawable/bg_action_btn"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_stop"
                style="@style/OpenCyvis.Button.Custom"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Stop"
                android:textSize="13sp"
                android:textColor="#EF4444"
                android:background="@drawable/bg_action_btn_danger"
                android:textAllCaps="false" />
        </LinearLayout>

        <!-- Input row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/edit_input"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:hint="Ask me anything..."
                android:inputType="text"
                android:background="@drawable/bg_input_field"
                android:paddingHorizontal="20dp"
                android:textSize="15sp"
                android:textColor="#E0FFFFFF"
                android:textColorHint="#40FFFFFF"
                android:maxLines="1"
                android:fontFamily="sans-serif" />

            <Button
                android:id="@+id/btn_voice_input"
                style="@style/OpenCyvis.Button.Custom"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:text="🎙"
                android:textSize="16sp"
                android:textColor="#B0FFFFFF"
                android:background="@drawable/bg_action_btn"
                android:padding="0dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_send"
                style="@style/OpenCyvis.Button.Custom"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="▲"
                android:textSize="16sp"
                android:textColor="#FF0D0D0D"
                android:background="@drawable/bg_btn_send"
                android:textStyle="bold"
                android:padding="0dp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
